{
    "version": 2,
    "functions": {
        "api/index.py": {
            "runtime": "@vercel/python@4.5.0",
            "maxDuration": 120
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/static/(.*)",
            "destination": "/static/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.py"
        }
    ]
}